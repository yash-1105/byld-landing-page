# ── BYLD Space signup function (/api/subscribe) ──
# Copy to .env.local for local `vercel dev`, and set the SAME two vars in Vercel
# (Project → Settings → Environment Variables) for production.
#
# The actual signup work (saving to the Google Sheet + sending the email from info@byldspace.com)
# happens in a Google Apps Script web app. This function just forwards to it securely.

# The Apps Script web app URL (ends with /exec). You get this after deploying apps-script/Code.gs.
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfyc.../exec

# A long random string of YOUR choice. Must EXACTLY match the SECRET set inside apps-script/Code.gs.
APPS_SCRIPT_SECRET=choose-a-long-random-string
